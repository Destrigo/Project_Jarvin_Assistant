# Mistral — https://console.mistral.ai/api-keys
MISTRAL_API_KEY=...

# Telegram — https://t.me/BotFather → /newbot
TELEGRAM_BOT_TOKEN=...
# Your personal Telegram chat_id (send /start to @userinfobot to find it)
TELEGRAM_CHAT_ID=...

# Google OAuth credentials (download from Google Cloud Console)
# https://console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client IDs
GOOGLE_CLIENT_SECRET_FILE=config/google_client_secret.json
# Scopes needed: gmail.modify, calendar

# Obsidian vault path (default: ~/Documents/Jarvis)
OBSIDIAN_VAULT=~/Documents/Jarvis
